-- ส่วนที่เหลือ (ฟังก์ชัน GetBestTarget, HumanizeAim, Main Loop ฯลฯ) เหมือนเดิมทุกประการ
-- (โค้ดส่วนนี้ไม่มีการเปลี่ยนแปลง ผมขอย่อเพื่อความยาวที่เหมาะสม)

local function GetPlayerTeam(player)
    return player.Team and player.Team.Name or "No Team"
end

local function IsAlive(player)
    return player.Character and 
           player.Character:FindFirstChild("Humanoid") and 
           player.Character.Humanoid.Health > 0
end

local function IsTargetAlive(targetPart)
    if not targetPart or not targetPart.Parent then return false end
    local humanoid = targetPart.Parent:FindFirstChild("Humanoid")
    return humanoid and humanoid.Health > 0
end

local function GetTargetPart(character)
    local parts = {Settings.AimPart, "Head", "HumanoidRootPart"}
    for _, partName in ipairs(parts) do
        local part = character:FindFirstChild(partName)
        if part then return part end
    end
    return nil
end

local function HasLineOfSight(targetPart)
    if not targetPart then return false end
    
    local cameraPos = Camera.CFrame.Position
    local direction = (targetPart.Position - cameraPos).unit
    local ray = Ray.new(cameraPos, direction * Settings.MaxDistance)
    local hit, hitPos = Workspace:FindPartOnRayWithIgnoreList(ray, {LocalPlayer.Character, Camera})
    
    if hit then
        local distanceToTarget = (targetPart.Position - cameraPos).Magnitude
        local distanceToHit = (hitPos - cameraPos).Magnitude
        return distanceToHit >= distanceToTarget - 5
    end
    return true
end

local function CalculatePriority(player, targetPart, isVisible)
    local score = 0
    local cameraPos = Camera.CFrame.Position
    local targetPos = targetPart.Position
    
    local distance = (targetPos - cameraPos).Magnitude
    local distanceScore = (Settings.MaxDistance - distance) / Settings.MaxDistance * 100
    score = score + distanceScore * (Settings.Weights.Distance / 100)
    
    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        local root = player.Character.HumanoidRootPart
        local lookVector = root.CFrame.LookVector
        local toPlayer = (LocalPlayer.Character.HumanoidRootPart.Position - root.Position).unit
        local dot = lookVector:Dot(toPlayer)
        
        local aimingScore = 0
        if dot > 0.7 then
            aimingScore = 100
        elseif dot > 0.3 then
            aimingScore = 50
        end
        score = score + aimingScore * (Settings.Weights.EnemyAiming / 100)
    end
    
    local partScore = targetPart.Name == Settings.AimPart and 100 or 50
    score = score + partScore * (Settings.Weights.BodyPart / 100)
    
    if isVisible then
        score = score + 30
    end
    
    return math.clamp(score, 0, 100)
end

local function IsInFOV(targetPart, fov)
    if not targetPart then return false end
    
    local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
    if not onScreen then return false end
    
    local distanceToCenter = (Vector2.new(screenPos.X, screenPos.Y) - Circle.Position).Magnitude
    return distanceToCenter <= fov
end

local function UpdateFOV()
    if CurrentMode == "LOCKED" then
        TargetFOV = Settings.FOV.Locked
        Circle.Color = Settings.Circle.Color.Locked
    elseif CurrentMode == "WALLBANG" then
        TargetFOV = Settings.FOV.Wallbang
        Circle.Color = Settings.Circle.Color.Wallbang
    else
        TargetFOV = Settings.FOV.Search
        Circle.Color = Settings.Circle.Color.Searching
    end
    
    CurrentFOV = CurrentFOV + (TargetFOV - CurrentFOV) * Settings.FOV.TransitionSpeed
    Circle.Radius = CurrentFOV
end

local function GetBestTarget()
    local visibleTargets = {}
    local allTargets = {}
    local myTeam = GetPlayerTeam(LocalPlayer)
    local screenCenter = Vector2.new(Circle.Position.X, Circle.Position.Y)
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and IsAlive(player) then
            local enemyTeam = GetPlayerTeam(player)
            
            local isEnemy = true
            if Settings.TeamCheck then
                if myTeam ~= "No Team" and enemyTeam ~= "No Team" and myTeam == enemyTeam then
                    isEnemy = false
                end
            end
            
            if isEnemy then
                local targetPart = GetTargetPart(player.Character)
                if targetPart then
                    local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                    if onScreen then
                        local distanceToCircle = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                        local distance3D = (targetPart.Position - Camera.CFrame.Position).Magnitude
                        
                        if distance3D <= Settings.MaxDistance and distanceToCircle <= CurrentFOV then
                            local hasLOS = HasLineOfSight(targetPart)
                            
                            if not Settings.Wallbang and not hasLOS then
                                continue
                            end
                            
                            local priority = CalculatePriority(player, targetPart, hasLOS)
                            
                            local targetData = {
                                Part = targetPart,
                                Player = player,
                                Priority = priority,
                                Distance = distance3D,
                                DistanceToCircle = distanceToCircle,
                                HasLOS = hasLOS,
                                ScreenPos = Vector2.new(screenPos.X, screenPos.Y)
                            }
                            
                            table.insert(allTargets, targetData)
                            if hasLOS then
                                table.insert(visibleTargets, targetData)
                            end
                        end
                    end
                end
            end
        end
    end
    
    if #visibleTargets > 0 then
        table.sort(visibleTargets, function(a, b)
            return a.Priority > b.Priority
        end)
        
        local bestVisible = visibleTargets[1]
        for _, target in ipairs(visibleTargets) do
            if target.Priority > bestVisible.Priority - 10 then
                if target.DistanceToCircle < bestVisible.DistanceToCircle then
                    bestVisible = target
                end
            end
        end
        
        CurrentMode = "LOCKED"
        return bestVisible.Part, bestVisible
        
    elseif #allTargets > 0 then
        table.sort(allTargets, function(a, b)
            return a.Priority > b.Priority
        end)
        
        CurrentMode = "WALLBANG"
        return allTargets[1].Part, allTargets[1]
    end
    
    CurrentMode = "SEARCHING"
    return nil, nil
end

local function HumanizeAim(targetPos)
    if not Settings.Humanizer.Enabled then return targetPos end
    
    if HumanizerDelay > 0 then
        HumanizerDelay = HumanizerDelay - 1
        return nil
    end
    
    local errorOffset = Vector3.new(
        (math.random() * 2 - 1) * Settings.Humanizer.AimError,
        (math.random() * 2 - 1) * Settings.Humanizer.AimError,
        (math.random() * 2 - 1) * Settings.Humanizer.AimError
    )
    
    if math.random(1, 100) <= Settings.Humanizer.BreakChance then
        return nil
    end
    
    return targetPos + errorOffset
end

local function GetDynamicLerpSpeed(distance)
    local speed = Settings.BaseLerpSpeed + (distance / Settings.MaxDistance) * 0.3
    return math.clamp(speed, 0.1, 0.4)
end

local function ShouldKeepCurrentTarget()
    if not CurrentTarget or not CurrentTargetData then return false end
    if not IsTargetAlive(CurrentTarget) then return false end
    
    if not IsInFOV(CurrentTarget, Settings.FOV.Locked) then
        return false
    end
    
    local hasLOS = HasLineOfSight(CurrentTarget)
    CurrentTargetData.HasLOS = hasLOS
    
    if hasLOS then
        CurrentMode = "LOCKED"
    else
        if not Settings.Wallbang then
            return false
        end
        CurrentMode = "WALLBANG"
    end
    
    return true
end

