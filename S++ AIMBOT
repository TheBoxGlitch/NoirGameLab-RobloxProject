        CurrentMode = "SEARCHING"
        CurrentFOV = Settings.FOV.Search
        HUD:UpdateStatus(AimbotEnabled, CurrentMode, CurrentFOV)
    end
end)

RunService.RenderStepped:Connect(function()
    if not AimbotEnabled then 
        HUD:UpdateStatus(false, CurrentMode, CurrentFOV)
        return 
    end
    
    local viewport = Camera.ViewportSize
    Circle.Position = Vector2.new(viewport.X / 2, viewport.Y / 2)
    
    if CurrentTarget and not ShouldKeepCurrentTarget() then
        CurrentTarget = nil
        CurrentTargetData = nil
        SmoothTargetPosition = nil
        CurrentMode = "SEARCHING"
    end
    
    FrameCounter = FrameCounter + 1
    if FrameCounter >= Settings.UpdateRate then
        FrameCounter = 0
        
        if not CurrentTarget then
            local newTarget, targetData = GetBestTarget()
            if newTarget then
                CurrentTarget = newTarget
                CurrentTargetData = targetData
                SmoothTargetPosition = nil
                HumanizerDelay = math.random(Settings.Humanizer.RandomDelay[1], 
                                            Settings.Humanizer.RandomDelay[2])
            end
        end
    end
    
    UpdateFOV()
    HUD:UpdateStatus(AimbotEnabled, CurrentMode, CurrentFOV)
    
    if CurrentTarget and CurrentTargetData then
        local cameraPos = Camera.CFrame.Position
        local targetPos = CurrentTarget.Position
        
        local humanizedPos = HumanizeAim(targetPos)
        if not humanizedPos then return end
        
        if not SmoothTargetPosition then
            SmoothTargetPosition = humanizedPos
        else
            SmoothTargetPosition = SmoothTargetPosition:Lerp(humanizedPos, 0.7)
        end
        
        local distance = (targetPos - cameraPos).Magnitude
        local currentSpeed = GetDynamicLerpSpeed(distance)
        
        local direction = (SmoothTargetPosition - cameraPos).unit
        Camera.CFrame = Camera.CFrame:Lerp(
            CFrame.new(cameraPos, cameraPos + direction),
            currentSpeed
        )
    end
end)

